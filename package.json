{
  "name": "@orbserv-labs/orb-wallet",
  "version": "0.1.2",
  "description": "TypeScript SDK for the orbserv agent wallet API — multi-chain wallets, x402 auto-pay, and spending policies for AI agents",
  "keywords": [
    "wallet",
    "agent-wallet",
    "x402",
    "solana",
    "base",
    "ethereum",
    "arbitrum",
    "usdc",
    "ai-agent",
    "orbserv"
  ],
  "homepage": "https://orbserv.co",
  "license": "MIT",
  "author": "orbserv Labs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "orb-wallet-mcp": "./mcp/dist/server.js"
  },
  "files": [
    "dist",
    "mcp/dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.build.json --module commonjs --outDir dist/cjs",
    "build:mcp": "tsc -p mcp/tsconfig.json",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build && npm run build:mcp",
    "clean": "rm -rf dist mcp/dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
